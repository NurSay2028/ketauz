# ============================================================
# KETA.COMP — Environment Variables
# Copy this file to .env.local and fill in the values
# ============================================================

# ---- Gmail SMTP (Nodemailer — works locally + Vercel) ----
# Gmail App Password olish:
#   Google Account → Security → 2-Step Verification (yoqish)
#   → App passwords → Create → "Mail" → 16-belgili parolni copy qiling
EMAIL_USER=keta.comp.dev@gmail.com
EMAIL_PASS=your_gmail_app_password_here

# ---- Site URL ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production: NEXT_PUBLIC_SITE_URL=https://keta-comp.pages.dev

# ---- Cloudflare deployment uchun Dashboard'da o'rnatish ----
# Workers & Pages → keta-comp → Settings → Environment variables
# EMAIL_USER=keta.comp.dev@gmail.com
# EMAIL_PASS=your_gmail_app_password_here
# NEXT_PUBLIC_SITE_URL=https://keta-comp.pages.dev
#
# ⚠ MUHIM: Nodemailer SMTP (TCP) Cloudflare Workers'da ishlamaydi.
# Cloudflare'da contact form ishlashi uchun Resend ishlatish kerak:
#   npm install resend
#   RESEND_API_KEY=re_xxxxxxxxxxxx
# va src/app/api/contact/route.ts ni Resend SDK bilan yangilash kerak.
